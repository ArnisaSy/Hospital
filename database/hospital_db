CREATE DATABASE hospital_db;
USE hospital_db;


CREATE TABLE Department (
    DepartmentID INT PRIMARY KEY,
    DepartmentName VARCHAR(100) NOT NULL UNIQUE
);


CREATE TABLE Doctor (
    DoctorID INT PRIMARY KEY,
    Name VARCHAR(100) NOT NULL,
    Specialization VARCHAR(100),
    DepartmentID INT,
    CONSTRAINT FK_Doctor_Department
        FOREIGN KEY (DepartmentID)
        REFERENCES Department(DepartmentID)
);

CREATE TABLE Patient (
    PatientID INT PRIMARY KEY,
    Name VARCHAR(100) NOT NULL,
    DateOfBirth DATE,
    Gender VARCHAR(10),
    Address VARCHAR(200)
);


CREATE TABLE Appointment (
    AppointmentID INT PRIMARY KEY,
    PatientID INT NOT NULL,
    DoctorID INT NOT NULL,
    VisitDate DATE NOT NULL,
    CONSTRAINT FK_App_Patient
        FOREIGN KEY (PatientID) REFERENCES Patient(PatientID),
    CONSTRAINT FK_App_Doctor
        FOREIGN KEY (DoctorID) REFERENCES Doctor(DoctorID)
);



CREATE TABLE Diagnosis (
    DiagnosisID INT PRIMARY KEY,
    AppointmentID INT NOT NULL,
    DiagnosisName VARCHAR(200) NOT NULL,
    CONSTRAINT FK_Diagnosis_Appointment
        FOREIGN KEY (AppointmentID)
        REFERENCES Appointment(AppointmentID)
);


CREATE TABLE Treatment (
    TreatmentID INT PRIMARY KEY,
    DiagnosisID INT NOT NULL,
    TreatmentName VARCHAR(200) NOT NULL,
    CONSTRAINT FK_Treatment_Diagnosis
        FOREIGN KEY (DiagnosisID)
        REFERENCES Diagnosis(DiagnosisID)
);


