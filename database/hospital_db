SELECT COUNT(*) AS TotalPatients FROM Patient;
SELECT COUNT(*) AS TotalDoctors FROM Doctor;
SELECT COUNT(*) AS TotalAppointments FROM Appointment;

SELECT p.Name AS Patient,
       d.Name AS Doctor,
       dep.DepartmentName,
       dg.DiagnosisName,
       t.TreatmentName
FROM Patient p
JOIN Appointment a ON p.PatientID = a.PatientID
JOIN Doctor d ON a.DoctorID = d.DoctorID
JOIN Department dep ON d.DepartmentID = dep.DepartmentID
JOIN Diagnosis dg ON a.AppointmentID = dg.AppointmentID
JOIN Treatment t ON dg.DiagnosisID = t.DiagnosisID;


SELECT d.Name AS Doctor, COUNT(*) AS TotalVisits
FROM Doctor d
JOIN Appointment a ON d.DoctorID = a.DoctorID
GROUP BY d.Name;

SELECT d.Name, COUNT(*) AS TotalVisits
FROM Doctor d
JOIN Appointment a ON d.DoctorID = a.DoctorID
GROUP BY d.Name
HAVING COUNT(*) >= 1;


SELECT p.Name
FROM Patient p
JOIN Appointment a ON p.PatientID = a.PatientID
GROUP BY p.Name
HAVING COUNT(*) >
(
  SELECT AVG(cnt)
  FROM (
      SELECT COUNT(*) AS cnt
      FROM Appointment
      GROUP BY PatientID
  ) x
);

SELECT Name,
CASE
  WHEN YEAR(GETDATE()) - YEAR(DateOfBirth) < 18 THEN 'Minor'
  WHEN YEAR(GETDATE()) - YEAR(DateOfBirth) BETWEEN 18 AND 65 THEN 'Adult'
  ELSE 'Senior'
END AS AgeGroup
FROM Patient;

SELECT p.Name AS Patient, d.Name AS Doctor, a.VisitDate
FROM Appointment a
JOIN Patient p ON a.PatientID = p.PatientID
JOIN Doctor d ON a.DoctorID = d.DoctorID;

SELECT p.Name, dep.DepartmentName
FROM Appointment a
JOIN Patient p ON a.PatientID = p.PatientID
JOIN Doctor d ON a.DoctorID = d.DoctorID
JOIN Department dep ON d.DepartmentID = dep.DepartmentID;

SELECT p.Name
FROM Patient p
LEFT JOIN Appointment a ON p.PatientID = a.PatientID
WHERE a.AppointmentID IS NULL;

SELECT d.Name, COUNT(*) AS TotalVisits
FROM Appointment a
JOIN Doctor d ON a.DoctorID = d.DoctorID
GROUP BY d.Name;


SELECT TOP 3 d.Name, COUNT(*) AS TotalVisits
FROM Appointment a
JOIN Doctor d ON a.DoctorID = d.DoctorID
GROUP BY d.Name
ORDER BY COUNT(*) DESC;

SELECT dep.DepartmentName, COUNT(dg.DiagnosisID) AS TotalDiagnoses
FROM Diagnosis dg
JOIN Appointment a ON dg.AppointmentID = a.AppointmentID
JOIN Doctor d ON a.DoctorID = d.DoctorID
JOIN Department dep ON d.DepartmentID = dep.DepartmentID
GROUP BY dep.DepartmentName;

SELECT p.Name, COUNT(*) AS Visits
FROM Appointment a
JOIN Patient p ON a.PatientID = p.PatientID
GROUP BY p.Name
HAVING COUNT(*) > 1;

SELECT TreatmentName, COUNT(*) AS UsedTimes
FROM Treatment
GROUP BY TreatmentName
ORDER BY UsedTimes DESC;

SELECT DISTINCT p.Name
FROM Patient p
JOIN Appointment a ON p.PatientID = a.PatientID
WHERE a.DoctorID IN (
    SELECT DoctorID
    FROM Doctor
    WHERE Specialization = 'Cardiologist'
);

SELECT *
FROM Appointment
ORDER BY VisitDate DESC;

SELECT Address, COUNT(*) AS TotalPatients
FROM Patient
GROUP BY Address;

SELECT d.Name, COUNT(*) AS TotalAppointments
FROM Doctor d
JOIN Appointment a ON d.DoctorID = a.DoctorID
GROUP BY d.Name
HAVING COUNT(*) > 1;

SELECT COUNT(*) AS TotalDiagnoses
FROM Diagnosis;

SELECT COUNT(*) AS TotalTreatments
FROM Treatment;
